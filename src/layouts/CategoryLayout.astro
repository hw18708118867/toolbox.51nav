---
import BaseLayout from './BaseLayout.astro';
import AnimatedIcon from '../components/common/AnimatedIcon.astro';
import Breadcrumb from '../components/layout/Breadcrumb.astro';
import Sidebar from '../components/layout/Sidebar.astro';
import { categories } from '../data/categories';
import type { ToolDefinition } from '../data/tools-registry';

interface Props {
  category: typeof categories[number];
  tools: ToolDefinition[];
}

const { category, tools } = Astro.props;
const breadcrumbItems = [
  { label: '首页', href: '/' },
  { label: category.name },
];
---

<BaseLayout title={`${category.name} - 在线工具`} description={category.description}>
  <div class="max-w-[1400px] mx-auto px-5 py-6">
    <Breadcrumb items={breadcrumbItems} />

    <div class="flex flex-col lg:flex-row gap-6 mt-4">
      <div class="flex-1 min-w-0">
        <h1 class="text-2xl md:text-3xl font-extrabold mb-2 tracking-tight" style="color: var(--color-text);">{category.name}</h1>
        <p class="mb-7 text-sm" style="color: var(--color-text-secondary);">{category.description}</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" data-reveal>
          {tools.map((tool, i) => (
            <a
              href={`/tools/${category.id}/${tool.id}`}
              class="glass-card group flex flex-col items-center gap-2 p-5 no-underline"
              style={`--i:${Math.min(i, 15)}`}
            >
              <AnimatedIcon toolId={tool.id} categoryFallback={tool.category} size={40} />
              <div class="text-center">
                <h3 class="font-semibold text-sm mb-1 transition-colors duration-300" style="color: var(--color-text);">{tool.name}</h3>
                <p class="text-xs leading-relaxed line-clamp-2" style="color: var(--color-text-secondary);">{tool.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>

      <aside class="w-full lg:w-[260px] shrink-0">
        <Sidebar currentCategory={category.id} />
      </aside>
    </div>
  </div>
</BaseLayout>
