---
// AnimatedIcon.astro — Rich "app icon" style tool icons with Q-bounce hover
// Props:
//   toolId: tool identifier (e.g. 'base64', 'aes', 'json-format')
//   categoryFallback: category ID used as fallback (e.g. 'encoding')
//   size?: pixel width/height (default 48)
//   animated?: enable hover bounce (default true)
import { getToolIcon } from '../../data/tool-icons';
export interface Props {
  toolId: string;
  categoryFallback?: string;
  size?: number;
  animated?: boolean;
}

const { toolId, categoryFallback, size = 48, animated = true } = Astro.props;
const def = getToolIcon(toolId);
const animClass = animated ? 'icon-bounce' : '';

// Category fallback gradients
const fallbackBg: Record<string, [string, string]> = {
  encoding:    ['#3b82f6', '#1d4ed8'],
  encryption:  ['#6366f1', '#3730a3'],
  hashing:     ['#8b5cf6', '#6d28d9'],
  text:        ['#14b8a6', '#0f766e'],
  regex:       ['#ec4899', '#be185d'],
  'data-format': ['#f59e0b', '#b45309'],
  network:     ['#0ea5e9', '#0369a1'],
  security:    ['#ef4444', '#b91c1c'],
  converter:   ['#10b981', '#047857'],
  image:       ['#f97316', '#c2410c'],
  css:         ['#a855f7', '#7e22ce'],
  javascript:  ['#eab308', '#a16207'],
  generator:   ['#84cc16', '#4d7c0f'],
  math:        ['#06b6d4', '#0e7490'],
  document:    ['#f43f5e', '#be123c'],
  analysis:    ['#22c55e', '#15803d'],
};

const [g1, g2] = def?.bg || (categoryFallback ? (fallbackBg[categoryFallback] || fallbackBg['encoding']) : fallbackBg['encoding']);
---

<span
  class:list={['inline-flex items-center justify-center shrink-0', animClass]}
  style={`width:${size}px; height:${size}px;`}
>
  <svg
    width={size}
    height={size}
    viewBox="0 0 48 48"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <!-- Background rounded rect with gradient -->
    <defs>
      <linearGradient id={`bg-${toolId}`} x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color={g1} />
        <stop offset="100%" stop-color={g2} />
      </linearGradient>
      <!-- Subtle gloss overlay -->
      <linearGradient id={`gloss-${toolId}`} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="white" stop-opacity="0.15" />
        <stop offset="100%" stop-color="white" stop-opacity="0" />
      </linearGradient>
    </defs>
    <!-- Rounded background -->
    <rect x="2" y="2" width="44" height="44" rx="11" fill={`url(#bg-${toolId})`} />
    <!-- Glossy highlight -->
    <rect x="2" y="2" width="44" height="22" rx="11" fill={`url(#gloss-${toolId})`} />
    <!-- Foreground symbol -->
    <g>
      {def?.fg ? <Fragment set:html={def.fg} /> : (
        <text x="24" y="30" text-anchor="middle" font-family="sans-serif" font-size="17" font-weight="bold" fill="white">?</text>
      )}
    </g>
  </svg>
</span>

<style is:global>
  /* Q-bounce on parent hover */
  .icon-bounce svg {
    transform-origin: center;
    transition: transform 0.15s ease;
  }

  .group:hover .icon-bounce svg {
    animation: q-bounce 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  @keyframes q-bounce {
    0%   { transform: scale(1); }
    35%  { transform: scale(1.13); }
    65%  { transform: scale(0.93); }
    100% { transform: scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .group:hover .icon-bounce svg {
      animation: none;
    }
  }
</style>
