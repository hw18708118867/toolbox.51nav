---
const currentYear = new Date().getFullYear();
---

<footer style="background: var(--glass-medium); backdrop-filter: blur(40px) saturate(200%); -webkit-backdrop-filter: blur(40px) saturate(200%); border-top: 1px solid var(--glass-border);">
  <div class="max-w-[1400px] mx-auto px-5 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- 关于 -->
      <div>
        <div class="flex items-center gap-2.5 mb-4">
          <div class="w-8 h-8 rounded-xl flex items-center justify-center text-white font-bold text-xs"
            style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);">
            D
          </div>
          <span class="font-semibold text-base tracking-tight" style="color: var(--color-text);">开发工具箱</span>
        </div>
        <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
          免费在线开发与安全工具，所有操作在浏览器本地完成，保障数据安全。
        </p>
        <p class="text-sm mt-4 font-semibold" style="color: var(--color-text);">联系我们</p>
        <p class="text-sm mt-1" style="color: var(--color-text-muted);">
          反馈问题、建议新功能，欢迎发邮件到<br/>
          <a href="mailto:miraclehuang611@gmail.com" class="no-underline transition-colors duration-200 hover:text-[var(--color-primary)] font-medium" style="color: var(--color-primary);">
            ✉ miraclehuang611@gmail.com
          </a>
        </p>
      </div>

      <div>
        <h4 class="font-semibold text-sm mb-4" style="color: var(--color-text);">编码加解密</h4>
        <ul class="space-y-2">
          <li><a href="/tools/encoding/" class="text-sm no-underline transition-colors duration-200" style="color: var(--color-text-secondary);">编码解码</a></li>
          <li><a href="/tools/encryption/" class="text-sm no-underline transition-colors duration-200" style="color: var(--color-text-secondary);">加密解密</a></li>
          <li><a href="/tools/hashing/" class="text-sm no-underline transition-colors duration-200" style="color: var(--color-text-secondary);">哈希散列</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-sm mb-4" style="color: var(--color-text);">开发工具</h4>
        <ul class="space-y-2">
          <li><a href="/tools/text/" class="text-sm no-underline transition-colors duration-200" style="color: var(--color-text-secondary);">文本处理</a></li>
          <li><a href="/tools/data-format/" class="text-sm no-underline transition-colors duration-200" style="color: var(--color-text-secondary);">数据格式</a></li>
          <li><a href="/tools/regex/" class="text-sm no-underline transition-colors duration-200" style="color: var(--color-text-secondary);">正则表达式</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-sm mb-4" style="color: var(--color-text);">更多工具</h4>
        <ul class="space-y-2">
          <li><a href="/tools/network/" class="text-sm no-underline transition-colors duration-200" style="color: var(--color-text-secondary);">网络工具</a></li>
          <li><a href="/tools/security/" class="text-sm no-underline transition-colors duration-200" style="color: var(--color-text-secondary);">安全工具</a></li>
          <li><a href="/tools/converter/" class="text-sm no-underline transition-colors duration-200" style="color: var(--color-text-secondary);">编程转换</a></li>
      <li><a href="/tutorials/" class="text-sm no-underline transition-colors duration-200" style="color: var(--color-text-secondary);">技术教程</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-5 text-center" style="border-top: 1px solid var(--glass-border);">
      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 mb-3">
        <a href="/privacy" class="text-sm no-underline transition-colors duration-200 hover:text-[var(--color-primary)]" style="color: var(--color-text-muted);">隐私政策</a>
        <a href="/terms" class="text-sm no-underline transition-colors duration-200 hover:text-[var(--color-primary)]" style="color: var(--color-text-muted);">服务条款</a>
      </div>
      <p class="text-sm" style="color: var(--color-text-muted);">
        © {currentYear} 开发工具箱 · 所有操作均在浏览器本地完成
      </p>
    </div>
  </div>
</footer>
