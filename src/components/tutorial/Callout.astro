---
export type CalloutType = 'info' | 'warning' | 'tip';
interface Props { type: CalloutType; }

const { type = 'info' } = Astro.props;

const colors: Record<CalloutType, string> = {
  info: 'var(--color-primary)',
  warning: 'var(--color-warning)',
  tip: 'var(--color-success)',
};

const labels: Record<CalloutType, string> = {
  info: '说明',
  warning: '注意',
  tip: '提示',
};
---

<div class="callout callout-{type}">
  <div class="callout-icon" style="color: {colors[type]};">
    {type === 'info' && (
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
    )}
    {type === 'warning' && (
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    )}
    {type === 'tip' && (
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
    )}
  </div>
  <div class="callout-body">
    <span class="callout-label" style="color: {colors[type]};">{labels[type]}</span>
    <div class="callout-content">
      <slot />
    </div>
  </div>
</div>

<style>
  .callout {
    display: flex;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: var(--glass-light);
  }
  .callout-icon {
    flex-shrink: 0;
    margin-top: 0.125rem;
  }
  .callout-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
    display: block;
  }
  .callout-content :global(p) {
    font-size: 0.875rem !important;
    line-height: 1.7 !important;
    margin-bottom: 0 !important;
  }
  .callout-content :global(a) {
    color: var(--color-primary);
  }
</style>
