---
import { getToolById } from '../../data/tools-registry';

interface Props {
  toolId: string;
}

const { toolId } = Astro.props;
const tool = getToolById(toolId);
if (!tool) return;
---

<a href={`/tools/${tool.category}/${tool.id}`} class="cta-card no-underline">
  <div class="cta-icon" style="background: var(--color-primary-light);">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5">
      <polyline points="5 12 3 12 12 3 21 12 19 12" />
      <path d="M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-7" />
      <polyline points="9 21 9 12 15 12 15 21" />
    </svg>
  </div>
  <div class="cta-text">
    <span class="cta-title" style="color: var(--color-text);">在线体验 {tool.name}</span>
    <span class="cta-desc" style="color: var(--color-text-muted);">{tool.description}</span>
  </div>
  <svg class="cta-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5">
    <polyline points="9 18 15 12 9 6" />
  </svg>
</a>

<style>
  .cta-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-primary-light);
    background: var(--color-primary-light);
    transition: all 0.3s ease;
    margin-top: 1.5rem;
  }
  .cta-card:hover {
    border-color: var(--color-primary);
    background: rgba(0, 113, 227, 0.06);
    transform: translateY(-1px);
  }
  .cta-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .cta-text {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .cta-title {
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1.3;
  }
  .cta-desc {
    font-size: 0.6875rem;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .cta-arrow {
    flex-shrink: 0;
  }
</style>
