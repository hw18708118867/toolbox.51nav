---
export interface RelatedTutorial {
  title: string;
  toolId: string;
  category: string;
  description: string;
}

interface Props {
  tutorials: RelatedTutorial[];
}

const { tutorials } = Astro.props;
if (!tutorials || tutorials.length === 0) return;
---

<div class="related-tutorials">
  <h3 class="related-heading">相关教程</h3>
  <div class="related-grid" data-reveal>
    {tutorials.map((t, i) => (
      <a href={`/tutorials/${t.toolId}`} class="related-card glass-card-light no-underline" style={`--i:${Math.min(i, 15)}`}>
        <span class="related-card-title" style="color: var(--color-text);">{t.title}</span>
        <span class="related-card-desc" style="color: var(--color-text-muted);">{t.description}</span>
      </a>
    ))}
  </div>
</div>

<style>
  .related-tutorials {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
  .related-heading {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--color-text);
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.75rem;
  }
  .related-card {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 1rem 1.25rem;
    border-radius: var(--radius-md);
    transition: all 0.3s ease;
  }
  .related-card:hover {
    transform: translateY(-2px);
  }
  .related-card-title {
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.4;
  }
  .related-card-desc {
    font-size: 0.75rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
