---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnimatedIcon from '../components/common/AnimatedIcon.astro';
import { categories } from '../data/categories';
import { getPopularTools, getToolsByCategory, tools } from '../data/tools-registry';

const popularTools = getPopularTools();
const categoryPreview = categories.map((cat) => ({
  ...cat,
  tools: getToolsByCategory(cat.id).slice(0, 3),
}));

// 首页 JSON-LD：WebSite（含搜索 Action）+ Organization
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "开发工具箱",
    "url": "https://toolbox.51nav.com/",
    "description": "免费在线开发与安全工具箱，170+ 常用工具一站式搞定",
    "inLanguage": "zh-CN",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://toolbox.51nav.com/tools/?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "开发工具箱",
    "url": "https://toolbox.51nav.com/",
    "logo": "https://toolbox.51nav.com/favicon.svg"
  }
];
---

<BaseLayout
  title="免费在线编码加解密工具"
  description="免费在线开发与安全工具箱，提供编码解码、加密解密、哈希计算、文本处理、数据格式转换等 170+ 常用工具，所有操作浏览器本地完成"
  keywords="在线工具,编码解码,加密解密,哈希计算,Base64,MD5,AES,JSON格式化,开发者工具"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Hero -->
  <section class="relative pt-20 pb-16 md:pt-28 md:pb-24">
    <div class="max-w-[760px] mx-auto px-5 text-center">
      <!-- 徽章 -->
      <div class="inline-flex items-center gap-2 mb-8 px-4 py-1.5 rounded-full text-xs font-medium"
        style="background: var(--color-primary-light); color: var(--color-primary);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        数据安全 · 浏览器本地处理 · 无需上传
      </div>

      <!-- 主标题 -->
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold mb-5 tracking-tight leading-none" style="color: var(--color-text);">
        开发<span class="text-gradient">工具箱</span>
      </h1>
      <p class="text-lg md:text-xl mb-3 leading-relaxed" style="color: var(--color-text-secondary);">
        免费在线开发与安全工具，<span class="font-semibold" style="color: var(--color-primary);">170+</span> 常用工具一站式搞定
      </p>
      <p class="text-sm" style="color: var(--color-text-muted);">
        编码解码 · 加密解密 · 哈希散列 · 文本处理 · 数据格式 · 网络工具
      </p>

      <!-- 搜索框 — 玻璃质感 -->
      <div class="mt-10 max-w-lg mx-auto">
        <div class="relative">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="2">
            <circle cx="11" cy="11" r="8" />
            <path d="m21 21-4.35-4.35" />
          </svg>
          <input
            type="text"
            id="tool-search"
            placeholder="搜索工具... (如: Base64、AES加密、JSON格式化)"
            class="w-full rounded-2xl border-0 pl-12 pr-20 py-3.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] transition-all duration-300"
            style="
              background: var(--glass-strong);
              backdrop-filter: blur(40px) saturate(200%);
              -webkit-backdrop-filter: blur(40px) saturate(200%);
              box-shadow: var(--shadow-md);
              color: var(--color-text);
            "
            autocomplete="off"
          />
          <kbd class="absolute right-4 top-1/2 -translate-y-1/2 hidden sm:inline-flex items-center gap-0.5 px-2 py-0.5 rounded-lg text-[10px] font-medium"
            style="background: var(--glass-light); color: var(--color-text-muted);">
            ⌘K
          </kbd>
        </div>
        <div id="search-results" class="hidden mt-3 rounded-2xl overflow-hidden" style="background: var(--glass-strong); backdrop-filter: blur(40px) saturate(200%); -webkit-backdrop-filter: blur(40px) saturate(200%); box-shadow: var(--shadow-xl); border: 1px solid var(--glass-border); max-height: 360px; overflow-y: auto;"></div>
      </div>

      <!-- 数据指标 -->
      <div class="mt-14 flex flex-wrap items-center justify-center gap-10 md:gap-14">
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-extrabold text-gradient">170+</div>
          <div class="text-xs mt-1.5" style="color: var(--color-text-muted);">在线工具</div>
        </div>
        <div class="w-px h-10 rounded-full" style="background: var(--glass-border);"></div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-extrabold" style="color: var(--color-primary);">16</div>
          <div class="text-xs mt-1.5" style="color: var(--color-text-muted);">工具分类</div>
        </div>
        <div class="w-px h-10 rounded-full" style="background: var(--glass-border);"></div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-extrabold" style="color: var(--color-accent);">100%</div>
          <div class="text-xs mt-1.5" style="color: var(--color-text-muted);">免费使用</div>
        </div>
      </div>
    </div>
  </section>

  <!-- 热门工具 -->
  <section class="max-w-[1400px] mx-auto px-5 pb-12">
    <div class="mb-6">
      <h2 class="text-xl md:text-2xl font-bold mb-1" style="color: var(--color-text);">🔥 热门工具</h2>
      <p class="text-sm" style="color: var(--color-text-muted);">开发者最常用的工具</p>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3" data-reveal>
      {popularTools.map((tool, i) => {
        const cat = categories.find(c => c.id === tool.category);
        return (
          <a
            href={`/tools/${tool.category}/${tool.id}`}
            class="glass-card group flex flex-col items-center gap-1.5 px-3 py-4 text-center no-underline"
            style={`--i:${Math.min(i, 15)}`}
          >
            <AnimatedIcon toolId={tool.id} categoryFallback={tool.category} size={40} />
            <span class="text-[13px] font-semibold transition-colors duration-300" style="color: var(--color-text);">{tool.name}</span>
            <span class="text-[11px]" style="color: var(--color-text-muted);">{cat?.name}</span>
          </a>
        );
      })}
    </div>
  </section>

  <!-- 工具分类 -->
  <section class="max-w-[1400px] mx-auto px-5 pb-20">
    <div class="mb-6">
      <h2 class="text-xl md:text-2xl font-bold mb-1" style="color: var(--color-text);">📂 工具分类</h2>
      <p class="text-sm" style="color: var(--color-text-muted);">16 大分类，覆盖开发全场景</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5" data-reveal>
      {categoryPreview.map((cat, i) => (
        <a
          href={`/tools/${cat.id}/`}
          class="glass-card group block p-6 no-underline"
          style={`--i:${Math.min(i, 15)}`}
        >
          <div class="flex items-center gap-3 mb-4">
            <AnimatedIcon toolId={cat.id} categoryFallback={cat.id} size={40} />
            <div class="flex-1 flex items-center justify-between">
              <h3 class="text-base font-bold transition-colors duration-300" style="color: var(--color-text);">{cat.name}</h3>
              <span class="text-xs px-2.5 py-1 rounded-full font-medium"
                style="background: var(--glass-light); color: var(--color-text-muted);">
                {cat.tools.length}+ 工具
              </span>
            </div>
          </div>
          <p class="text-sm mb-4 leading-relaxed" style="color: var(--color-text-secondary);">{cat.description}</p>
          <div class="flex flex-wrap gap-2">
            {cat.tools.map((tool) => (
              <span class="text-xs px-2.5 py-1 rounded-lg font-medium"
                style="background: var(--glass-light); color: var(--color-text-muted);">
                {tool.name}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- 底部信任标识 -->
  <section style="background: var(--glass-medium); backdrop-filter: blur(40px) saturate(200%); -webkit-backdrop-filter: blur(40px) saturate(200%); border-top: 1px solid var(--glass-border);">
    <div class="max-w-[1400px] mx-auto px-5 py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 text-center">
        <div class="px-4">
          <div class="w-14 h-14 mx-auto mb-5 rounded-2xl flex items-center justify-center text-2xl transition-transform duration-500 hover:scale-110"
            style="background: var(--glass-light);">
            🔒
          </div>
          <h3 class="text-base font-bold mb-2" style="color: var(--color-text);">数据安全</h3>
          <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">所有操作均在浏览器本地完成，数据不会上传到任何服务器</p>
        </div>
        <div class="px-4">
          <div class="w-14 h-14 mx-auto mb-5 rounded-2xl flex items-center justify-center text-2xl transition-transform duration-500 hover:scale-110"
            style="background: var(--glass-light);">
            ⚡
          </div>
          <h3 class="text-base font-bold mb-2" style="color: var(--color-text);">无需安装</h3>
          <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">无需下载安装任何软件，打开浏览器即可使用全部功能</p>
        </div>
        <div class="px-4">
          <div class="w-14 h-14 mx-auto mb-5 rounded-2xl flex items-center justify-center text-2xl transition-transform duration-500 hover:scale-110"
            style="background: var(--glass-light);">
            🆓
          </div>
          <h3 class="text-base font-bold mb-2" style="color: var(--color-text);">完全免费</h3>
          <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">所有工具完全免费使用，无注册要求，无使用次数限制</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<!-- 客户端搜索 -->
<script define:vars={{ toolIndex: tools.map(t => ({ n: t.name, d: t.id, c: t.category, k: t.keywords.join(' ') })) }}>
  const searchInput = document.getElementById('tool-search');
  const searchResults = document.getElementById('search-results');

  if (searchInput && searchResults) {
    searchInput.addEventListener('input', (e) => {
      const query = e.target.value.trim().toLowerCase();
      if (!query) {
        searchResults.classList.add('hidden');
        return;
      }

      const matches = toolIndex.filter(t =>
        t.n.toLowerCase().includes(query) ||
        t.k.toLowerCase().includes(query)
      ).slice(0, 8);

      if (matches.length === 0) {
        searchResults.innerHTML = '<div class="px-4 py-3 text-sm" style="color: var(--color-text-muted);">未找到匹配的工具</div>';
      } else {
        searchResults.innerHTML = matches.map(t =>
          `<a href="/tools/${t.c}/${t.d}" class="flex items-center justify-between px-4 py-3 no-underline transition-colors duration-200" style="color: var(--color-text);" onmouseover="this.style.backgroundColor='var(--glass-light)'" onmouseout="this.style.backgroundColor='transparent'">
            <div class="flex flex-col gap-0.5">
              <span class="text-sm font-semibold">${t.n}</span>
              <span class="text-[11px]" style="color: var(--color-text-muted);">${t.c}</span>
            </div>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
          </a>`
        ).join('');
      }
      searchResults.classList.remove('hidden');
    });

    document.addEventListener('click', (e) => {
      if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
        searchResults.classList.add('hidden');
      }
    });
  }
</script>
