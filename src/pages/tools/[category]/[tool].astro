      // 图片
      ImageCompressTool: 'image/ImageCompressTool.vue', ImageConvertTool: 'image/ImageConvertTool.vue',
      ImageBase64Tool: 'image/ImageBase64Tool.vue', ImageMetadataTool: 'image/ImageMetadataTool.vue',
      ImageResizeTool: 'image/ImageResizeTool.vue', ImageCropTool: 'image/ImageCropTool.vue',
      ImageWatermarkTool: 'image/ImageWatermarkTool.vue', ImageSplitTool: 'image/ImageSplitTool.vue',
      SvgOptimizerTool: 'image/SvgOptimizerTool.vue', IcoConvertTool: 'image/IcoConvertTool.vue',
      FaviconGenTool: 'image/FaviconGenTool.vue',
      // CSS
      CssMinifyTool: 'css/CssMinifyTool.vue', CssGradientTool: 'css/CssGradientTool.vue',
      CssShadowTool: 'css/CssShadowTool.vue', CssFlexboxTool: 'css/CssFlexboxTool.vue',
