      // JavaScript
      JsMinifyTool: 'javascript/JsMinifyTool.vue', JsFormatTool: 'javascript/JsFormatTool.vue',
      JsRunTool: 'javascript/JsRunTool.vue', JsObfuscateTool: 'javascript/JsObfuscateTool.vue',
      JsBeautifyTool: 'javascript/JsBeautifyTool.vue', JsDeobfuscateTool: 'javascript/JsDeobfuscateTool.vue',
      BabelTransformTool: 'javascript/BabelTransformTool.vue', TypescriptPlayTool: 'javascript/TypescriptPlayTool.vue',
      // 生成工具
      UuidTool: 'generator/UuidTool.vue', FakeDataTool: 'generator/FakeDataTool.vue',
      UlidTool: 'generator/UlidTool.vue', NanoidTool: 'generator/NanoidTool.vue',
      RandomStringTool: 'generator/RandomStringTool.vue', RandomNumberTool: 'generator/RandomNumberTool.vue',
      HashBatchTool: 'generator/HashBatchTool.vue', ChineseLoremTool: 'generator/ChineseLoremTool.vue',
      // 数学
      BaseCalculatorTool: 'math/BaseCalculatorTool.vue', BitCalculatorTool: 'math/BitCalculatorTool.vue',
      MathExpressionTool: 'math/MathExpressionTool.vue', PercentageCalcTool: 'math/PercentageCalcTool.vue',
      BmiCalcTool: 'math/BmiCalcTool.vue',
      // 文档
      JsonToTsTool: 'document/JsonToTsTool.vue', JsonToGoTool: 'document/JsonToGoTool.vue',
      HtmlToMdTool: 'document/HtmlToMdTool.vue', MdToHtmlTool: 'document/MdToHtmlTool.vue',
      CsvToSqlTool: 'data-format/CsvToSqlTool.vue', SqlToCsvTool: 'data-format/SqlToCsvTool.vue',
      JsonToJavaTool: 'document/JsonToJavaTool.vue', JsonToMysqlTool: 'document/JsonToMysqlTool.vue',
      ExcelToJsonTool: 'document/ExcelToJsonTool.vue', PdfToTextTool: 'document/PdfToTextTool.vue',
      // 数据分析
      FrequencyAnalysisTool: 'text/FrequencyAnalysisTool.vue',
      EntropyCalcTool: 'text/EntropyCalcTool.vue', BaseDetectTool: 'encoding/BaseDetectTool.vue',
      CharsetDetectTool: 'encoding/CharsetDetectTool.vue', BinaryAnalysisTool: 'security/BinaryAnalysisTool.vue',
    };

    const relPath = pathMap[componentName];
    if (!relPath) {
      mount.innerHTML = '<p class="text-center py-8" style="color: var(--color-text-muted);">该工具正在开发中，敬请期待...</p>';
      return;
    }

    try {
      const { createApp } = await import('vue');
      const mod = await import(`../../../components/tools/${relPath}`);
      const Component = mod.default;
      if (Component) {
        const app = createApp(Component);
        mount.innerHTML = '';
        const wrapper = document.createElement('div');
        mount.appendChild(wrapper);
        app.mount(wrapper);
      }
    } catch (err) {
      mount.innerHTML = '<p class="text-center py-8" style="color: var(--color-error);">组件加载失败，请刷新页面重试</p>';
    }
  })();
</script>
