---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnimatedIcon from '../../components/common/AnimatedIcon.astro';
import Breadcrumb from '../../components/layout/Breadcrumb.astro';
import { categories } from '../../data/categories';
import { getToolsByCategory } from '../../data/tools-registry';

const breadcrumbItems = [
  { label: '首页', href: '/' },
  { label: '全部工具' },
];

const totalTools = categories.reduce((sum, cat) => sum + getToolsByCategory(cat.id).length, 0);
---

<BaseLayout
  title="全部在线工具"
  description={`开发工具箱全部在线工具索引，共 ${totalTools}+ 个工具，覆盖编码解码、加密解密、哈希、文本、数据格式、网络、安全等 ${categories.length} 大分类。`}
  keywords="在线工具,工具大全,工具索引,开发工具,编码,加密,哈希,网络安全工具"
>
  <div class="max-w-[1400px] mx-auto px-5 py-6">
    <Breadcrumb items={breadcrumbItems} />

    <div class="mt-4 mb-8">
      <h1 class="text-2xl md:text-3xl font-extrabold mb-2 tracking-tight" style="color: var(--color-text);">全部在线工具</h1>
      <p class="text-sm" style="color: var(--color-text-secondary);">
        共 <strong style="color: var(--color-primary);">{totalTools}</strong> 个工具，分布在 {categories.length} 大分类中，所有操作均在浏览器本地完成。
      </p>
      <div class="mt-5 max-w-lg">
        <input
          type="text"
          id="tools-filter"
          placeholder="搜索工具名... (如: Base64、AES、JSON)"
          class="w-full rounded-2xl border-0 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] transition-all duration-300"
          style="background: var(--glass-strong); color: var(--color-text);"
          autocomplete="off"
        />
      </div>
    </div>

    {categories.map((cat) => {
      const catTools = getToolsByCategory(cat.id);
      return (
        <section class="mb-10">
          <div class="flex items-center gap-3 mb-4">
            <AnimatedIcon toolId={cat.id} categoryFallback={cat.id} size={36} />
            <div class="flex-1">
              <a href={`/tools/${cat.id}/`} class="text-lg md:text-xl font-bold transition-colors duration-300" style="color: var(--color-text);">
                {cat.name}
              </a>
              <p class="text-xs mt-0.5" style="color: var(--color-text-muted);">{cat.description}</p>
            </div>
            <span class="text-xs px-2.5 py-1 rounded-full font-medium whitespace-nowrap"
              style="background: var(--glass-light); color: var(--color-text-muted);">
              {catTools.length} 个工具
            </span>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3" data-reveal>
            {catTools.map((tool, i) => (
              <a
                href={`/tools/${cat.id}/${tool.id}`}
                class="glass-card group flex flex-col items-center gap-1.5 p-4 no-underline text-center"
                style={`--i:${Math.min(i, 15)}`}
              >
                <AnimatedIcon toolId={tool.id} categoryFallback={tool.category} size={34} />
                <span class="text-[13px] font-semibold transition-colors duration-300" style="color: var(--color-text);">{tool.name}</span>
              </a>
            ))}
          </div>
        </section>
      );
    })}
  </div>
</BaseLayout>

<!-- 客户端工具过滤（支持 ?q= 参数，配合首页 Sitelinks 搜索框） -->
<script define:vars={{ toolIndex: categories.flatMap(cat => getToolsByCategory(cat.id).map(t => ({ n: t.name, c: cat.id, d: t.id }))) }}>
  const params = new URLSearchParams(window.location.search);
  const q = (params.get('q') || '').trim();
  const input = document.getElementById('tools-filter');
  const sections = document.querySelectorAll('section');

  function applyFilter(query) {
    const ql = query.toLowerCase();
    sections.forEach(section => {
      const links = section.querySelectorAll('a[href^="/tools/"]');
      let visible = 0;
      links.forEach(a => {
        const name = a.querySelector('span')?.textContent || '';
        const match = !ql || name.toLowerCase().includes(ql);
        a.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      section.style.display = (ql && visible === 0) ? 'none' : '';
    });
  }

  if (input) {
    if (q) input.value = q;
    applyFilter(q);
    input.addEventListener('input', (e) => applyFilter(e.target.value));
  }
</script>
